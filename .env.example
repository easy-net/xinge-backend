APP_ENV=development
DATABASE_URL=sqlite+pysqlite:////tmp/xinge.db
ENCRYPTION_KEY=replace-with-a-32-char-or-longer-secret-key
ALLOW_EPHEMERAL_DB=false
SEED_SCHOOL_FIXTURES_ON_STARTUP=true
HOST=0.0.0.0
PORT=8000
SSL_CERTFILE=
SSL_KEYFILE=
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1

PAYMENT_MODE=mock
WECHAT_APP_ID=replace-with-mini-program-app-id
WECHAT_APP_SECRET=replace-with-mini-program-app-secret
WECHAT_MCH_ID=replace-with-wechat-mch-id
WECHAT_NOTIFY_URL=https://example.com/api/v1/payments/notify
WECHAT_TRANSFER_NOTIFY_URL=https://example.com/api/v1/payments/transfer/notify
WECHAT_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WECHAT_SERIAL_NO=replace-with-wechat-serial-no
WECHAT_API_V3_KEY=replace-with-api-v3-key
WECHAT_PLATFORM_CERT_PATH=./certs/wechatpay_platform.pem
WECHAT_PLATFORM_SERIAL_NO=
WECHAT_CALLBACK_TOLERANCE=300
WECHAT_TRANSFER_SCENE_ID=1005
WECHAT_TRANSFER_REMARK=分销佣金提现
WECHAT_TRANSFER_USER_RECV_PERCEPTION=劳务报酬
WECHAT_TRANSFER_REPORT_PRIMARY=校园分销
WECHAT_TRANSFER_REPORT_SECONDARY=分销佣金提现
DISTRIBUTOR_WITHDRAW_AUTO_APPROVE_FEN=10000
UNSAFE_ADMIN_WITHDRAW_APPROVE=false
WECHAT_VERIFY_SSL=true
WECHAT_CA_BUNDLE_PATH=

DEV_AUTH_BYPASS=false
LOG_MP_REPORT_PAYLOADS=false
UNSAFE_DISABLE_VALIDATION=false
LOG_CURRENT_USER_RESOLUTION=false
LOG_ALL_API_PAYLOADS=true
