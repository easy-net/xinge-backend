APP_ENV=production
DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/xinge_backend
ENCRYPTION_KEY=replace-with-a-32-char-or-longer-secret-key
ALLOW_EPHEMERAL_DB=false
PORT=80
PAYMENT_MODE=mock
WECHAT_APP_ID=replace-with-mini-program-app-id
WECHAT_APP_SECRET=replace-with-mini-program-app-secret
WECHAT_MCH_ID=replace-with-wechat-mchid
WECHAT_NOTIFY_URL=https://example.com/api/v1/mp/orders/notify/wechat
WECHAT_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WECHAT_SERIAL_NO=replace-with-merchant-cert-serial
WECHAT_API_V3_KEY=replace-with-32-char-apiv3-key
WECHAT_PLATFORM_CERT_PATH=./certs/wechatpay_platform.pem
WECHAT_PLATFORM_SERIAL_NO=
WECHAT_CALLBACK_TOLERANCE=300
AUTH_TOKEN_TTL_SECONDS=86400
DEV_AUTH_BYPASS=true
LOG_MP_REPORT_PAYLOADS=false
LOG_ALL_API_PAYLOADS=false
UNSAFE_DISABLE_VALIDATION=true
LOG_CURRENT_USER_RESOLUTION=false
